{
  "name": "seele",
  "version": "2.3.0",
  "description": "Seele \u80a1\u7968\u6570\u636e\u7ba1\u7406\u7cfb\u7edf - \u524d\u540e\u7aef\u7edf\u4e00\u5165\u53e3",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev:back\" \"npm run dev:front\"",
    "dev:front": "cd seele-frontend && npm run serve",
    "dev:back": "cd seele-backend && python start.py",
    "build": "cd seele-frontend && npm run build",
    "lint": "cd seele-frontend && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^9.0.0"
  },
  "workspaces": [
    "seele-frontend"
  ]
}
