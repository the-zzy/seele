# ==========================================
# 部署环境: dev | prod
# dev = 开发模式（高并发、热重载）
# prod = 生产模式（2核2GB 优化）
# ==========================================
DEPLOY_ENV=dev

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=seele

# 应用配置
APP_HOST=0.0.0.0
APP_PORT=9000

# Moonshot AI (Kimi) 配置
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2.6

# （可选）以下参数会覆盖 DEPLOY_ENV 的自动推导值
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=5
# SYNC_MAX_WORKERS=2
